---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects', ({ data }) => !data.draft ?? true);
const featuredProjects = allProjects.sort((a, b) => a.data.order - b.data.order).slice(0, 3);

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 3);

const techStack = [
  { name: 'Python', emoji: '🐍' },
  { name: 'R-language', emoji: '📊' },
  { name: 'SPSS', emoji: '📉' },
  { name: 'SQL', emoji: '🗄️' },
  { name: 'QGIS / QFIELD', emoji: '🗺️' },
  { name: 'Power BI', emoji: '📈' },
  { name: 'Excel (Power Query)', emoji: '📑' },
  { name: 'KoboToolbox / ODK', emoji: '📋' },
];
---

<BaseLayout title="Home — Statistician, Data Scientist & GIS Specialist">
  <Navbar />

  <main>
    <!-- ═══════════════ HERO ═══════════════ -->
    <section class="hero" aria-label="Introduction">
      <div class="container" style="display:grid;grid-template-columns:repeat(auto-fit, minmax(320px, 1fr));gap:var(--space-12);align-items:center;">
        <!-- Left side: Text -->
        <div>
          <div class="hero-eyebrow" style="margin-bottom:var(--space-4);">
            <span class="status-dot" style="color:var(--color-accent-green);font-weight:600;letter-spacing:0.05em;">
              Available for Consultations, Research & Data Roles
            </span>
          </div>

          <h1 class="hero-title font-display" style="font-size:clamp(2.5rem, 6vw, 4rem);line-height:1.1;margin-bottom:var(--space-6);">
            Yaji Timothy <span class="gradient-text">Terungwa</span>
          </h1>

          <h2 class="font-display text-secondary" style="font-size:var(--text-h2);font-weight:700;margin-bottom:var(--space-4);">
            Turning Complex Data Into Actionable Statistical Insights.
          </h2>

          <p class="hero-subtitle" style="font-size:var(--text-base);color:var(--color-text-secondary);line-height:var(--leading-relaxed);margin-bottom:var(--space-8);">
            A Statistician &amp; Data Scientist with 10+ years of experience in statistical modeling, spatial data collection (GIS), process automation, and high-stakes data management. Ph.D. Candidate in Statistics.
          </p>

          <div class="hero-actions">
            <a href="/work" class="btn btn-primary btn-lg" id="hero-work-btn">
              View Projects &amp; Work →
            </a>
            <a href="/about" class="btn btn-ghost btn-lg" id="hero-about-btn">
              Read My Full CV 📄
            </a>
          </div>
        </div>

        <!-- Right side: Photo & Profile Summary Card -->
        <div class="animate-in" style="position:relative;display:flex;justify-content:center;align-items:center;">
          <!-- Glow effect -->
          <div style="position:absolute;inset:-10px;border-radius:var(--radius-xl);background:var(--color-gradient-cyan);opacity:0.15;filter:blur(24px);"></div>
          <!-- Card container -->
          <div class="card card-inner" style="width:100%;max-width:360px;position:relative;border-color:var(--color-border-glow);display:flex;flex-direction:column;gap:var(--space-4);background:var(--color-gradient-card);">
            <div style="width:100%;aspect-ratio:1;border-radius:var(--radius-lg);overflow:hidden;border:1px solid var(--color-border);">
              <img src="/images/yaji-photo.jpg" alt="Yaji Timothy Terungwa" style="width:100%;height:100%;object-fit:cover;" />
            </div>
            <div>
              <h3 class="font-display" style="font-size:var(--text-h4);font-weight:700;margin-bottom:2px;">Yaji Timothy Terungwa</h3>
              <p class="text-xs text-cyan" style="font-weight:600;letter-spacing:0.05em;text-transform:uppercase;">Statistician &amp; Data Scientist</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Scroll indicator -->
      <div style="position:absolute;bottom:var(--space-8);left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:var(--space-2);opacity:0.4;">
        <span style="font-size:var(--text-xs);letter-spacing:0.2em;text-transform:uppercase;color:var(--color-text-secondary)">Scroll</span>
        <div style="width:1px;height:48px;background:linear-gradient(to bottom,var(--color-text-secondary),transparent);"></div>
      </div>
    </section>

    <!-- ═══════════════ STATS BAR ═══════════════ -->
    <section style="padding-bottom:var(--space-12);" aria-label="Key statistics">
      <div class="container">
        <div style="display:grid;grid-template-columns:repeat(auto-fit, minmax(200px, 1fr));gap:var(--space-6);background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius-lg);padding:var(--space-6) var(--space-8);text-align:center;">
          <div style="padding:var(--space-2);">
            <div style="font-size:var(--text-h1);font-family:var(--font-display);font-weight:800;color:var(--color-accent-cyan);">$2.5M</div>
            <div style="font-size:var(--text-xs);color:var(--color-text-secondary);text-transform:uppercase;letter-spacing:0.05em;margin-top:var(--space-1);">World Bank Grant Qualified</div>
          </div>
          <div style="padding:var(--space-2);border-inline:1px solid var(--color-border);">
            <div style="font-size:var(--text-h1);font-family:var(--font-display);font-weight:800;color:var(--color-accent-cyan);">10+ Yrs</div>
            <div style="font-size:var(--text-xs);color:var(--color-text-secondary);text-transform:uppercase;letter-spacing:0.05em;margin-top:var(--space-1);">Professional Experience</div>
          </div>
          <div style="padding:var(--space-2);">
            <div style="font-size:var(--text-h1);font-family:var(--font-display);font-weight:800;color:var(--color-accent-cyan);">3,000+</div>
            <div style="font-size:var(--text-xs);color:var(--color-text-secondary);text-transform:uppercase;letter-spacing:0.05em;margin-top:var(--space-1);">Weekly Records Processed</div>
          </div>
          <div style="padding:var(--space-2);border-left:1px solid var(--color-border);">
            <div style="font-size:var(--text-h1);font-family:var(--font-display);font-weight:800;color:var(--color-accent-cyan);">Ph.D.</div>
            <div style="font-size:var(--text-xs);color:var(--color-text-secondary);text-transform:uppercase;letter-spacing:0.05em;margin-top:var(--space-1);">Candidate in Statistics</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════ BENTO GRID ═══════════════ -->
    <section class="section-sm" aria-label="Highlights">
      <div class="container">
        <div class="bento-grid">

          <!-- Featured Project — large cell -->
          {featuredProjects[0] && (
            <div class="card bento-cell bento-col-8 bento-row-2 animate-in project-card" id="featured-project-card">
              <div class="project-card-cover" style="border-radius:var(--radius-lg) var(--radius-lg) 0 0;height:200px;overflow:hidden;">
                {featuredProjects[0].data.coverImage ? (
                  <img src={featuredProjects[0].data.coverImage} alt={featuredProjects[0].data.title} style="width:100%;height:100%;object-fit:cover;" />
                ) : (
                  <div style="width:100%;height:100%;background:linear-gradient(135deg,#0d1117,#1a2e26);display:flex;align-items:center;justify-content:center;">
                    <span style="font-size:3rem;">🗺️</span>
                  </div>
                )}
              </div>
              <div class="project-card-body">
                <div class="project-card-tags">
                  {featuredProjects[0].data.tags.slice(0,3).map(tag => (
                    <span class="badge badge-cyan">{tag}</span>
                  ))}
                </div>
                <h2 class="project-card-title font-display">{featuredProjects[0].data.title}</h2>
                <p class="project-card-desc">{featuredProjects[0].data.description}</p>
                <a href={`/work/${featuredProjects[0].slug}`} class="project-card-link">
                  View Case Study →
                </a>
              </div>
            </div>
          )}

          <!-- Tech Stack card -->
          <div class="card bento-cell bento-col-4 animate-in card-inner" style="animation-delay:100ms;" id="tech-stack-card">
            <div class="badge badge-surface" style="margin-bottom:var(--space-4);">Data &amp; Stats Stack</div>
            <div class="tech-stack">
              {techStack.map(t => (
                <span class="tech-pill">{t.emoji} {t.name}</span>
              ))}
            </div>
          </div>

          <!-- Academic & Professional Status card -->
          <div class="card bento-cell bento-col-4 animate-in card-inner" style="animation-delay:150ms;background:linear-gradient(135deg,rgba(34,197,94,0.08),rgba(0,212,255,0.08));border-color:rgba(34,197,94,0.2);" id="availability-card">
            <div class="status-dot" style="color:var(--color-accent-green);margin-bottom:var(--space-3);">
              Ph.D. Statistics (In View)
            </div>
            <p class="text-sm" style="color:var(--color-text-secondary);line-height:var(--leading-relaxed);">
              Specializing in Multi-Auxiliary Two-Phase Sampling and Multiple Imputation. Member of CISON &amp; GEOSON.
            </p>
            <a href="/about" class="btn btn-ghost" style="margin-top:var(--space-4);font-size:var(--text-xs);">
              View Education &amp; Bio →
            </a>
          </div>

          <!-- Latest blog post -->
          {latestPosts[0] && (
            <div class="card bento-cell bento-col-4 animate-in card-inner" style="animation-delay:200ms;" id="latest-post-card">
              <div class="badge badge-violet" style="margin-bottom:var(--space-3);">
                Featured Research
              </div>
              <h3 class="font-display" style="font-size:var(--text-h4);font-weight:700;margin-bottom:var(--space-2);line-height:var(--leading-snug);">
                {latestPosts[0].data.title}
              </h3>
              <p class="text-sm text-secondary" style="margin-bottom:var(--space-4);line-height:var(--leading-relaxed);">
                {latestPosts[0].data.description.slice(0, 100)}...
              </p>
              <a href={`/blog/${latestPosts[0].slug}`} class="project-card-link">
                Read Article →
              </a>
            </div>
          )}

        </div>
      </div>
    </section>

    <!-- ═══════════════ SELECTED WORK ═══════════════ -->
    <section class="section" aria-label="Selected projects">
      <div class="container">
        <div class="section-header flex-between" style="flex-wrap:wrap;gap:var(--space-4);">
          <div>
            <span class="section-label">Portfolio</span>
            <h2 class="section-title">
              Featured <span class="underline-cyan">Projects</span>
            </h2>
          </div>
          <a href="/work" class="btn btn-ghost" id="all-work-btn">View All Projects →</a>
        </div>

        <div class="grid-3">
          {featuredProjects.map((project, i) => (
            <article class={`card project-card animate-in`} style={`animation-delay:${i * 80}ms`} id={`project-${project.slug}`}>
              <div class="project-card-cover" style="overflow:hidden;">
                {project.data.coverImage ? (
                  <img src={project.data.coverImage} alt={project.data.title} style="width:100%;height:100%;object-fit:cover;" />
                ) : (
                  <div style="width:100%;height:100%;background:linear-gradient(135deg,#0d1117,#1a2e26,#0d2a1f);display:flex;align-items:center;justify-content:center;font-size:2.5rem;">
                    {i === 0 ? '🗺️' : i === 1 ? '🔒' : '🐍'}
                  </div>
                )}
              </div>
              <div class="project-card-body">
                <div class="project-card-tags">
                  {project.data.tags.slice(0,3).map(tag => (
                    <span class="badge badge-surface">{tag}</span>
                  ))}
                </div>
                <h3 class="project-card-title font-display">{project.data.title}</h3>
                <p class="project-card-desc">{project.data.description.slice(0, 120)}...</p>
                <a href={`/work/${project.slug}`} class="project-card-link">
                  View Project Case Study →
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════ BLOG PREVIEW ═══════════════ -->
    <section class="section" style="padding-top:0;" aria-label="Latest articles and insights">
      <div class="container">
        <div class="section-header flex-between" style="flex-wrap:wrap;gap:var(--space-4);">
          <div>
            <span class="section-label">Publications &amp; Insights</span>
            <h2 class="section-title">
              Articles &amp; <span class="underline-cyan">Research</span>
            </h2>
          </div>
          <a href="/blog" class="btn btn-ghost" id="all-posts-btn">All Articles →</a>
        </div>

        <div class="grid-3">
          {latestPosts.map((post, i) => (
            <article class={`card blog-card animate-in`} style={`animation-delay:${i * 80}ms`} id={`home-post-${post.slug}`}>
              <div class="blog-card-cover">
                <div style={`width:100%;height:100%;background:linear-gradient(135deg,${i===0?'#0d1a2e,#1a2e4a':i===1?'#1a0d2e,#2e1a4a':'#0d2e1a,#1a4a2e'});display:flex;align-items:center;justify-content:center;font-size:2rem;`}>
                  {i === 0 ? '📊' : i === 1 ? '🗺️' : '📈'}
                </div>
              </div>
              <div class="blog-card-body">
                <div class="blog-card-meta">
                  <span class={`badge badge-${i===0?'cyan':i===1?'violet':'surface'}`}>{post.data.category}</span>
                  <span>·</span>
                  <span>{post.data.readingTime ?? 5} min read</span>
                </div>
                <h3 class="blog-card-title font-display">{post.data.title}</h3>
                <p class="blog-card-excerpt">{post.data.description.slice(0, 100)}...</p>
                <a href={`/blog/${post.slug}`} class="project-card-link">
                  Read Article →
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════ CONTACT CTA ═══════════════ -->
    <section class="section" style="padding-top:0;" aria-label="Contact call to action">
      <div class="container">
        <div class="contact-card animate-in" id="contact-cta" style="max-width:640px;margin:0 auto;padding:var(--space-8);">
          <span class="section-label" style="justify-content:center;display:block;margin-bottom:var(--space-4);">
            Get In Touch
          </span>
          <h2 class="font-display" style="font-size:var(--text-h2);font-weight:800;letter-spacing:-0.02em;margin-bottom:var(--space-4);text-align:center;">
            Need Data Science &amp; Statistical Expertise?
          </h2>
          <p class="text-secondary" style="max-width:540px;margin:0 auto var(--space-6);line-height:var(--leading-relaxed);text-align:center;">
            Whether you need assistance with spatial data collection, statistical modeling, automated reporting, or research collaboration — feel free to send a message.
          </p>
          
          <form action="https://formspree.io/f/xdaqlzbl" method="POST" style="display:flex;flex-direction:column;gap:var(--space-4);text-align:left;max-width:480px;margin:0 auto;">
            <div>
              <label for="name" style="font-size:var(--text-xs);font-weight:600;color:var(--color-text-secondary);text-transform:uppercase;letter-spacing:0.05em;display:block;margin-bottom:var(--space-2);">Full Name</label>
              <input type="text" id="name" name="name" required style="width:100%;padding:var(--space-3) var(--space-4);background:var(--color-surface-raised);border:1px solid var(--color-border);border-radius:var(--radius-sm);color:var(--color-text-primary);font-family:var(--font-body);transition:border-color var(--transition-fast);" />
            </div>
            <div>
              <label for="email" style="font-size:var(--text-xs);font-weight:600;color:var(--color-text-secondary);text-transform:uppercase;letter-spacing:0.05em;display:block;margin-bottom:var(--space-2);">Email Address</label>
              <input type="email" id="email" name="email" required style="width:100%;padding:var(--space-3) var(--space-4);background:var(--color-surface-raised);border:1px solid var(--color-border);border-radius:var(--radius-sm);color:var(--color-text-primary);font-family:var(--font-body);transition:border-color var(--transition-fast);" />
            </div>
            <div>
              <label for="message" style="font-size:var(--text-xs);font-weight:600;color:var(--color-text-secondary);text-transform:uppercase;letter-spacing:0.05em;display:block;margin-bottom:var(--space-2);">Your Message</label>
              <textarea id="message" name="message" rows="5" required style="width:100%;padding:var(--space-3) var(--space-4);background:var(--color-surface-raised);border:1px solid var(--color-border);border-radius:var(--radius-sm);color:var(--color-text-primary);font-family:var(--font-body);resize:vertical;transition:border-color var(--transition-fast);"></textarea>
            </div>
            <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:var(--space-4);">Send Message →</button>
          </form>

          <div style="display:flex;gap:var(--space-4);justify-content:center;margin-top:var(--space-6);flex-wrap:wrap;font-size:var(--text-sm);color:var(--color-text-secondary);">
            <span>📞 Call: <a href="tel:07062439948" style="color:var(--color-accent-cyan);font-weight:600;">07062439948</a></span>
            <span>·</span>
            <span>✉️ Email: <a href="mailto:tertimothy@gmail.com" style="color:var(--color-accent-cyan);font-weight:600;">tertimothy@gmail.com</a></span>
          </div>

          <div style="display:flex;gap:var(--space-3);justify-content:center;margin-top:var(--space-4);flex-wrap:wrap;">
            <a href="https://github.com/Timoyaj" target="_blank" rel="noopener noreferrer" class="btn btn-ghost">GitHub</a>
            <a href="https://www.linkedin.com/in/timothy-yaji/" target="_blank" rel="noopener noreferrer" class="btn btn-ghost">LinkedIn</a>
            <a href="https://web.facebook.com/tertimothy" target="_blank" rel="noopener noreferrer" class="btn btn-ghost">Facebook</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
